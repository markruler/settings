{
  "permissions": {
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read(*.md)",

      "Bash(source:*)",
      "Bash(git:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(curl:*)",
      "Bash(xargs:*)",
      "Bash(awk:*)",

      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(**/pip:*)",
      "Bash(**/python:*)",

      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",

      "Bash(mvn:*)",
      "Bash(./mvnw:*)",
      "Bash(gradle:*)",
      "Bash(./gradlew:*)",

      "Bash(* -v)",
      "Bash(* --verbose)",
      "Bash(* --version)",
      "Bash(* version)",
      "Bash(* --help *)"
    ],
    "deny": [
      "Bash(git push *)"
    ],
    "ask": [
      "Bash(rm *)"
    ]
  }
}
